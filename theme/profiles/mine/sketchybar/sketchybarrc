#!/usr/bin/env zsh

FONT_FACE="JetBrainsMono Nerd Font"

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
ITEM_DIR="$HOME/.config/sketchybar/items"

SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"

source "$HOME/.config/sketchybar/colors.sh"

# ── wm detection (aerospace vs rift) ──
# (whichever wm is running drives the space pills. rift uses the *_rift.sh
# counterparts; defaults to aerospace when rift isn't up.)
if pgrep -x rift >/dev/null 2>&1; then
  WS_CHANGE_EVENT=rift_workspace_change
  SPACES_ITEMS="$ITEM_DIR/spaces_rift.sh"
  WINDOWS_PLUGIN="$PLUGIN_DIR/space_windows_rift.sh"
else
  WS_CHANGE_EVENT=aerospace_workspace_change
  SPACES_ITEMS="$ITEM_DIR/spaces.sh"
  WINDOWS_PLUGIN="$PLUGIN_DIR/space_windows.sh"
fi

sketchybar --bar \
    height=32 \
    color=0x00000000 \
    sticky=on \
    padding_left=23 \
    padding_right=23 \
    notch_width=188 \
    display=main

# Alternatiive background colors
# label.color=0xffffffff
# background.color=0x9924273a
sketchybar --default \
    background.color=0x66${SK_COLOR8#0xff} \
    background.corner_radius=5 \
    background.padding_right=5 \
    background.height=26 \
    icon.font="$FONT_FACE:Medium:15.0" \
    icon.padding_left=5 \
    icon.padding_right=5 \
    label.font="$FONT_FACE:Medium:12.0" \
    label.color=$SK_FOREGROUND \
    label.y_offset=0 \
    label.padding_left=0 \
    label.padding_right=5

source "$ITEM_DIR/static_icon.sh"
FONT_FACE="$FONT_FACE" PLUGIN_DIR="$PLUGIN_DIR" SK_COLOR3="$SK_COLOR3" bash "$SPACES_ITEMS"

source "$ITEM_DIR/moon.sh"
# source "$ITEM_DIR/weather.sh"
source "$ITEM_DIR/spotify.sh"

source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/theme_toggle.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/ram.sh"
source "$ITEM_DIR/tailscale.sh"

WS_CHANGE_EVENT="$WS_CHANGE_EVENT" WINDOWS_PLUGIN="$WINDOWS_PLUGIN" source "$ITEM_DIR/space_updater.sh"

##### Finalizing Setup #####
sketchybar --update
sketchybar --trigger "$WS_CHANGE_EVENT"
sketchybar --trigger volume_change
