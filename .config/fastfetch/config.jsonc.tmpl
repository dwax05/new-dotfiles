{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  // Generated from config.jsonc.tmpl by ~/.config/wal/postrun - do not edit config.jsonc by hand
  "logo": {
    "type": "kitty-direct",
    "width": 20, // Width in characters (height auto from aspect)
    "padding": {
      "top": 1, // Top padding
      "left": 1, // Left padding
      "right": 2 // Right padding
    },
    "color": { // Override logo colors
      "1": "%COLOR4%",
      "2": "%COLOR2%"
    }
  },
  "display": {
    "separator": " ", // Separator between keys and values
    "color": {
      "keys": "%COLOR4%", // Key color
      "title": "%COLOR1%" // Title color
    },
    "key": {
      "width": 12, // Aligns keys to this width
      "type": "both" // string, icon, both, or none
    },
    "bar": {
      "width": 10, // Width of percentage bars
      "char": {
        "elapsed": "■", // Character for elapsed portion
        "total": "-", // Character for total portion
      },
    },
    "percent": {
      "type": 9, // 1=number, 2=bar, 3=both, 9=colored number
      "color": {
        "green": "%COLOR2%",
        "yellow": "%COLOR3%",
        "red": "%COLOR1%"
      }
    }
  },
  "modules": [
    {
      "type": "custom",
      "format": "╭──────────────────────────────────────"
    },
    {
      "key": " user ",
      "type": "title",
      "format": "{user-name}",
      "keyColor": "%COLOR1%"
    },
    {
      "key": "│",
      "type": "command",
      "text": "system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Model Name/{print $2; exit}'",
      "key": " hname",
      "keyColor": "%COLOR2%"
    },
    {
      "key": "│",
      "type": "uptime",
      "key": " uptime",
      "keyColor": "%COLOR3%"
    },
    {
      "type": "custom",
      "format": "╰──────────────────────────────────────"
    },
    {
      "type": "custom",
      "format": "╭──────────────────────────────────────"
    },
    {
      "key": "│",
      "type": "os",
      "key": " distro",
      "keyColor": "%COLOR4%",
      "format": "{name} {codename} {version} {arch}"
    },
    {
      "key": "│",
      "type": "kernel",
      "key": " kernel",
      "keyColor": "%COLOR5%"
    },
    {
      "key": "│",
      "type": "terminal",
      "key": " term ",
      "keyColor": "%COLOR6%"
    },
    {
      "type": "custom",
      "format": "╰──────────────────────────────────────"
    },
    {
      "type": "custom",
      "format": "╭──────────────────────────────────────"
    },
    {
      "key": "│",
      "type": "cpu",
      "key": " cpu ",
      "keyColor": "%COLOR4%"
    },
    {
      "key": "│",
      "type": "disk",
      "key": " disk ",
      "keyColor": "%COLOR5%",
      "folders": "/",
      "format": "{size-used} / {size-total} ({size-percentage})"
    },
    {
      "key": "│",
      "type": "memory",
      "key": " memory",
      "keyColor": "%COLOR6%"
    },
    {
      "type": "custom",
      "format": "╰──────────────────────────────────────"
    }
  ]
}
